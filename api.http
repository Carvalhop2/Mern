GET {{baseUrl}}/books
Content-Type:{{contentType}}
###
GET {{baseUrl}}/books/id
Content-Type:{{contentType}}

###
/*Atualiza um livro existente, ou seja, uma pesquisa por id*/
PUT {{baseUrl}}/books/ID_AQUI
Content-Type: {{contentType}}

{
  "subtitle": "Python 3.12",
  "author": "Goku"
}


