@host = http://localhost:3000
@baseUrl = {{host}}/api/v1
@contentType = application/json

POST {{baseUrl}}/books
Content-Type: {{contentType}}

{
  "title": "Java como Programar",
  "subtitle": "Aprenda Java em 21 anos",
